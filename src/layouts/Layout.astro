---
import "../styles/global.css";
import Header from "./Header.astro";

interface Props {
	title?: string;
}

const { title = "" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.45/dist/katex.min.css" integrity="sha384-UA8juhPf75SzzAMA/4fo3yOU7sBJ0om7SCD2GHq0fZqZco6tr1UCV7nUbk9J90JM" crossorigin="anonymous">
		<meta name="generator" content={Astro.generator} />
		<title>{title && `${title} | `} Malb7mm's kyopro_blog</title>
	</head>
	<body>
		<div class="tw:bg-p-30 tw:py-5 tw:px-5 tw:w-full tw:h-full tw:flex tw:flex-row">
			<header class="tw:w-60 tw:h-full">
				<Header/>
			</header>
			<div class="tw:overflow-y-scroll tw:grow">
				<div class="tw:pb-40 tw:pt-10">
					<slot />
				</div>
			</div>
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	:global(pre.astro-code) {
  	background-color: var(--tw-color-p-70) !important;
		border: solid 1px var(--tw-color-p-200)
	}
</style>
